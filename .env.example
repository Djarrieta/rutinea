# Supabase (production)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key> # from Supabase dashboard: Settings → API → Project API keys

# Supabase Pooler connection (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.<project-ref>:<your-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── Local development (copy to .env.local) ───
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:5002
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-status>
# DATABASE_URL=postgresql://postgres:postgres@localhost:5003/postgres
